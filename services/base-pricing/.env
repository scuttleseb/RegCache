# Base Pricing Microservice Environment Configuration
# Save this as: services/base-pricing/.env

# Service Configuration
PORT=3002
NODE_ENV=development
SERVICE_NAME=base-pricing-microservice
SERVICE_VERSION=1.0.0

# Database Configuration (MySQL) - Shared with RegCache
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=rootpassword123
DB_NAME=appliance_registration
DB_PORT=3306

# Redis Configuration - Shared with RegCache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PASSWORD is empty because we didn't set one in Docker

# CORS Configuration - Allow RegCache frontend to call this service
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching Settings
PRICE_CACHE_TTL=3600
SESSION_CACHE_TTL=1800

# Logging
LOG_LEVEL=debug

# Production Settings (for when you deploy this service separately)
# DB_HOST=your-rds-endpoint.amazonaws.com
# REDIS_HOST=your-elasticache-endpoint.amazonaws.com
# PORT=80
# NODE_ENV=production