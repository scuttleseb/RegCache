# Backend Environment Configuration
# Save this as: backend/.env

# Database Configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=rootpassword123
DB_NAME=appliance_registration
DB_PORT=3306

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PASSWORD is empty because we didn't set one in Docker

# Server Configuration
PORT=3001
NODE_ENV=development

# Security Configuration (optional for development)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_SECRET=your_session_secret_here_change_in_production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
# This allows your React frontend to make requests to the backend

# Rate Limiting (requests per minute)
RATE_LIMIT_MAX=100

# Logging Level
LOG_LEVEL=debug

# Cache Settings
CACHE_TTL=3600
# Time-to-live for cached pricing data (1 hour = 3600 seconds)

# Production Settings (for when you deploy)
# DB_HOST=your-rds-endpoint.amazonaws.com
# REDIS_HOST=your-elasticache-endpoint.amazonaws.com
# NODE_ENV=production
# PORT=80